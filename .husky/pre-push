#!/usr/bin/env sh
# SpeechAngel pre-push hook (plain shell — husky-compatible, but husky is NOT installed).
# Enable with:  git config core.hooksPath .husky      (see CLAUDE.md §3)
#
# Runs the guardrail bundle, then the Gradle quality + core-test gate with the captured
# JDK 21 / ANDROID_HOME environment (CLAUDE.md §1.2). Heavier than pre-commit by design.

set -e

NODE_BIN="$(command -v node || true)"
if [ -z "$NODE_BIN" ]; then
  NODE_BIN="/home/arsvivendi/.nvm/versions/node/v24.16.0/bin/node"
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo "[pre-push] running guardrails:check ..."
"$NODE_BIN" scripts/audits/run-all.mjs

echo "[pre-push] running Gradle quality + core test gate (JDK 21 + Android SDK) ..."
JAVA_HOME=/usr/lib/jvm/java-21-openjdk-amd64 \
ANDROID_HOME=/home/arsvivendi/Android/Sdk \
"$REPO_ROOT/gradlew" -p "$REPO_ROOT" \
  detekt \
  spotlessCheck \
  :app:lintDebug \
  test \
  :app:assembleDebug

# `test` runs every module's JVM unit tests (core + :data + :app); :app:assembleDebug + :app:lintDebug
# were verified green on this host 2026-06-28 ("wire only what is green"), so they are gated here.
#
# TODO (still deferred): instrumentation tests (:app:connectedDebugAndroidTest) require a running
# emulator/device and are NOT added to pre-push — they belong in a manual/CI on-device job, not a
# gate that would block every push when no emulator is attached.

echo "[pre-push] OK"
